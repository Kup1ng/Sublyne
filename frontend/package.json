{
  "name": "sublyne-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Sublyne web panel — Vue 3 + Nuxt 3 + Tailwind SPA",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build && node scripts/build-spa-index.mjs",
    "preview": "nuxt preview",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "nuxt prepare && vue-tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "lucide-vue-next": "^0.469.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^3.15.4",
    "@nuxtjs/tailwindcss": "^6.13.1",
    "@types/node": "^22.10.5",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "happy-dom": "^16.5.3",
    "nuxt": "^3.15.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^3.0.2",
    "vue-tsc": "^2.2.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.4"
}
